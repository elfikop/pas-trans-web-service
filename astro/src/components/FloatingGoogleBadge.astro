---
// src/components/FloatingGoogleBadge.astro

const placeId = import.meta.env.GOOGLE_PLACE_ID || "";

// Link do wizytówki w Google
const mapsLink = `https://g.page/r/CUNC57o5coPcEBM/`;

// Zahardkodowana wartość opinii (zmień ją tutaj w dowolnej chwili)
const googleRating = "4.9";
---

<a href={mapsLink} target="_blank" rel="noopener noreferrer" class="floating-google-badge" aria-label="Sprawdź nasze opinie w Google">
  <div class="badge-inner">
    
    <div class="badge-top">
      <span class="rating-score">{googleRating}</span>
      <div class="stars">
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
      </div>
    </div>

    <div class="badge-middle">
      <svg class="bg-shapes" viewBox="0 0 100 40" preserveAspectRatio="none">
        <polygon points="0,0 50,20 100,0" fill="#4285F4" /> <polygon points="0,0 50,20 0,40" fill="#EA4335" />  <polygon points="100,0 50,20 100,40" fill="#34A853" /> <polygon points="0,40 50,20 100,40" fill="#FBBC05" /> </svg>
      
      <div class="g-circle">
        <svg viewBox="0 0 24 24" width="10" height="10" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z" fill="#4285F4"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z" fill="#4285F4"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#4285F4"/>
        </svg>
      </div>
    </div>

    <div class="badge-bottom">
      Dziesiątki Zadowolonych<br/>Klientów
    </div>
    
  </div>
</a>

<style>
  .floating-google-badge {
    position: fixed;
    bottom: 90px; 
    right: 20px;
    background-color: #ffffff;
    padding: 1.5px;
    border-radius: 32.5px 32.5px 8px 8px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    text-decoration: none;
    z-index: 999;
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }

  .floating-google-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 3px 8px rgba(0,0,0,0.2);
  }

  .badge-inner {
    width: 52.5px; 
    background: #ffffff;
    border-radius: 31px 31px 6.5px 6.5px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .badge-top {
    background: #4285F4;
    padding: 9px 0 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rating-score {
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    margin-bottom: 2px;
    letter-spacing: -0.25px;
  }

  .stars {
    display: flex;
    gap: 1px;
  }

  .stars svg {
    width: 6.5px;
    height: 6.5px;
    fill: #ffffff;
  }

  .badge-middle {
    position: relative;
    height: 17.5px;
    width: 100%;
    background: #ffffff;
  }

  .bg-shapes {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .g-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .badge-bottom {
    background: #ffffff;
    color: #202124;
    font-size: 6.5px;
    font-weight: 700;
    text-align: center;
    line-height: 1.3;
    padding: 4px 2.5px 7px;
  }

  /* RWD dla urządzeń mobilnych - Skalowanie usunięte zgodnie z wytycznymi */
  @media (max-width: 768px) {
    .floating-google-badge {
      bottom: 80px; 
      right: 20px;
    }
    .floating-google-badge:hover {
      transform: translateY(-2px);
    }
  }
</style>