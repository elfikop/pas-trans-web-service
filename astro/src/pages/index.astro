---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { getImage } from 'astro:assets';

// 1. Astro bierze WSZYSTKO co wrzucisz do tego folderu
const imageFiles = import.meta.glob('/src/assets/slider/*.{jpeg,jpg,png,webp}', { eager: true });

// 2. Od razu optymalizuje do WebP (nie musimy niczego filtrować, bo są tu tylko zdjęcia z galerii)
const sliderImages = await Promise.all(
    Object.values(imageFiles).map(async (image) => {
        return await getImage({
            src: image.default,
            format: 'webp',
            quality: 85
        });
    })
);
---

<BaseLayout 
    title="Pas-Trans Marcin Pastuch - Wynajem Autokarów i Transport"
    description="Profesjonalne usługi transportowe Pas-Trans. Wynajem autokarów, busów 9-osobowych oraz przewozy szkolne w Gryfowie Śląskim i na całym Dolnym Śląsku."
    keywords="autobus, transport, pas-trans, marcin pastuch, wynajem autokarów, Gryfów Śląski, przewozy szkolne, wynajem busa"
    canonical="https://autokarypastrans.pl/"
    ogTitle="Pas-Trans Marcin Pastuch - Usługi Transportowe"
    ogDescription="Profesjonalne usługi transportowe i wynajem autokarów w Gryfowie Śląskim. Sprawdź naszą ofertę!"
    ogUrl="https://autokarypastrans.pl/"
>
    <Fragment slot="head">
        <script type="application/ld+json">
            {
            "@context": "https://schema.org",
            "@type": "BusReservationService",
            "description": "Profesjonalne usługi transportowe, wynajem autokarów i busów w Gryfowie Śląskim i na terenie Dolnego Śląska.",
            "name": "Pas-Trans Marcin Pastuch",
            "image": "https://autokarypastrans.pl/logo.png",
            "@id": "https://autokarypastrans.pl",
            "url": "https://autokarypastrans.pl",
            "telephone": "+48665339661",
            "priceRange": "$$",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "ul. Spacerowa 15",
                "addressLocality": "Gryfów Śląski",
                "postalCode": "59-620",
                "addressCountry": "PL"
            },
            "geo": {
                "@type": "GeoCoordinates",
                "latitude": 51.03229, 
                "longitude": 15.40075
            },
            "openingHoursSpecification": {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
                "Sunday"
                ],
                "opens": "06:00",
                "closes": "21:00"
            },
            "sameAs": [
                "https://www.facebook.com/people/Autokary-Pas-Trans/61564448867373/",
                "https://g.page/r/CUNC57o5coPcEBM/"
            ]
            },
            "areaServed": [
                {
                "@type": "State",
                "name": "Województwo Dolnośląskie"
                },
                {
                "@type": "Country",
                "name": "Polska"
                }
            ]
        </script>
        <meta property="og:image:type" content="image/png">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
    </Fragment>

    <Navbar />

    <header id="hero">
        <div class="container hero-flex">
            <div class="hero-text">
                <h1>Pas-Trans Marcin Pastuch – Wynajem autokarów i usługi transportowe</h1>
                <h2>Marcin Pastuch</h2>
                <ul>
                    <li>Wynajem pojazdów</li>
                    <li>Zamów autokar</li>
                    <li>Przewozy szkolno-pracownicze</li>
                </ul>
                <a href="#kontakt" class="btn hero-btn">Skontaktuj się z nami</a>
            </div>
            <div class="hero-img">
                <img src="/galeria/hero.webp" alt="Nasz autokar">
            </div>
        </div>
    </header>

    <section id="opinie" class="container">
        <h2 class="section-title">Zaufany Przewoźnik</h2>
        <div id="rekomendacje">
            <script type="text/plain" class="opt-in" src="https://static.elfsight.com/platform/platform.js" data-use-service-core defer></script>
            <div class="elfsight-app-b2432883-7334-40bf-bb08-64fcd77e78f2" data-elfsight-app-lazy></div>
        </div>
    </section>

    <section id="cytat">
        <div class="container">
            <blockquote>
                "Bądź wzorcem jakości. Niektórzy ludzie nie przywykli do środowiska, gdzie oczekuje się doskonałości." -
                <span>Steve Jobs</span>
            </blockquote>
        </div>
    </section>

    <section id="oferta-sekcja" class="container">
        <h2 class="section-title">Oferta PAS-TRANS</h2>
        <div class="oferta-grid">
            <div class="card">
                <h3>Wynajem autokaru</h3>
                <p>Licencjonowany przewoźnik z Dolnego Śląska. Obsługujemy szkoły, kluby i biura podróży w kraju i za granicą:</p>
                <ul style="text-align: left; list-style-type: disc; margin-bottom: 15px; padding-left: 20px; font-size: 0.9rem;">
                    <li><strong>Nowoczesna flota:</strong> Autokary 8–50 miejsc (m.in. Scania oraz NOWOŚĆ 2025: luksusowy Mercedes 26 os.).</li>
                    <li><strong>Bezpieczeństwo:</strong> Doświadczeni kierowcy i regularnie serwisowane pojazdy.</li>
                    <li><strong>Doświadczenie:</strong> Punktualność i indywidualne podejście do każdego zlecenia.</li>
                </ul>
                <a href="/wynajem-autokaru/" class="btn">Szczegóły</a>
            </div>
            <div class="card">
            <h3>Autobus szkolny</h3>
            <p>Obsługujemy regularne przewozy na trasach:</p>
            <ul style="text-align: left; list-style-type: disc; margin-bottom: 15px; padding-left: 20px;">
                <li>Miłoszów – Leśna – Gryfów – Biedrzychowice – Lubań</li>
                 <li>Zgorzelec – Sulików – Lubań – Olszyna – Gryfów Śląski</li>
                </ul>
             <p>Sprawdź nasz aktualny rozkład jazdy poniżej.</p>
                <a href="/rozklad-jazdy/" class="btn">Rozkład Jazdy</a>
            </div>
            <div class="card">
                <h3>Wypożyczalnia busów</h3>
                <p>Oferujemy wynajem nowoczesnych busów 9-osobowych (kat. B) na wyjazdy wakacyjne, zimowe oraz okolicznościowe:</p>
                <ul style="text-align: left; list-style-type: disc; margin-bottom: 15px; padding-left: 20px; font-size: 0.9rem;">
                    <li><strong>Atrakcyjne ceny:</strong> Konkurencyjne stawki dobowe dopasowane do długości najmu.</li>
                    <li><strong>Przejrzysta umowa:</strong> Proste i korzystne warunki bez ukrytych kosztów oraz limitów kilometrów.</li>
                </ul>
                <a href="/busy/" class="btn">Szczegóły</a>
            </div>
        </div>
    </section>

    <section id="galeria-slider" class="container">
        <h2 class="section-title">Nasza Flota w obiektywie</h2>
        <div class="slider-wrapper">
            <div class="slider">
                
                {sliderImages.map((img, index) => (
                    <div class={`slide ${index === 0 ? 'active' : ''}`}>
                        <img src={img.src} alt={`Flota Pas-Trans - zdjęcie ${index + 1}`} loading="lazy" />
                    </div>
                ))}

                <button class="prev" onclick="changeSlide(-1)">❮</button>
                <button class="next" onclick="changeSlide(1)">❯</button>
            </div>
            <div class="dots-container" id="dotsContainer"></div>
        </div>
    </section>

    <section id="o-nas" class="container">
        <h2 class="section-title">O firmie Pas-Trans – Twój partner w transporcie</h2>
        <div class="o-nas-flex">
            <div class="o-nas-content">
                <h3>Pasja, doświadczenie i najwyższe standardy bezpieczeństwa</h3>
                <p>
                    Firma <strong>Pas-Trans Marcin Pastuch</strong>, z siedzibą w <a href="/wynajem-autokaru/Gryfow-Slaski/" style="color: inherit; font-weight: bold; text-decoration: underline; text-decoration-color: var(--primary);">Gryfowie Śląskim</a>, to dynamicznie rozwijający się lider rynku <strong>wynajmu autokarów na Dolnym Śląsku</strong>. Nasza historia to tysiące bezpiecznie przejechanych kilometrów i setki zadowolonych pasażerów, którzy zaufali nam w kwestii <strong>transportu osób</strong>. Łączymy wieloletnie doświadczenie za kierownicą z nowoczesnym podejściem do logistyki, oferując kompleksowy <strong>wynajem busów i autokarów</strong> na terenie całej Polski oraz Europy.
                </p>
                
                <p>
                    Specjalizujemy się w obsłudze najbardziej wymagających zleceń – od <strong>wycieczek szkolnych</strong> i dowozu dzieci, przez profesjonalny <strong>transport dla firm</strong>, aż po luksusowe <strong>przewozy autokarowe na wesela</strong> i eventy okolicznościowe. Działamy lokalnie w takich miejscowościach jak <a href="/wynajem-autokaru/Luban/" style="color: inherit; font-weight: bold; text-decoration: underline; text-decoration-color: var(--primary);">Lubań</a>, <a href="/wynajem-autokaru/Zgorzelec/" style="color: inherit; font-weight: bold; text-decoration: underline; text-decoration-color: var(--primary);">Zgorzelec</a> czy <a href="/wynajem-autokaru/Boleslawiec/" style="color: inherit; font-weight: bold; text-decoration: underline; text-decoration-color: var(--primary);">Bolesławiec</a>, ale nasze horyzonty sięgają daleko poza granice regionu.
                </p>

                <div class="misja-box">
                    <h4>Nasza Misja: Komfortowa podróż „od drzwi do drzwi”</h4>
                    <p>Nadrzędnym celem Pas-Trans jest zapewnienie pasażerom atmosfery pełnego bezpieczeństwa i spokoju. Stawiamy na <strong>punktualność, rzetelność oraz elastyczność</strong> – każdą trasę planujemy tak, aby zoptymalizować czas i koszty przejazdu przy zachowaniu najwyższego komfortu podróży.</p>
                </div>

                <div class="atuty-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 30px;">
                    <div class="atut-item">
                        <i class="icon-ok" style="color: #fecb2f; font-size: 1.5rem;"></i>
                        <strong>Wieloletnie doświadczenie rynkowe</strong>
                        <p>Znamy trasy Dolnego Śląska i Europy jak nikt inny. Nasza wiedza pozwala nam omijać utrudnienia i zawsze docierać do celu na czas.</p>
                    </div>
                    <div class="atut-item">
                        <i class="icon-users" style="color: #fecb2f; font-size: 1.5rem;"></i>
                        <strong>Zróżnicowana flota 2025</strong>
                        <p>Dysponujemy pojazdami na każdą okazję: od ekonomicznych <strong>busów 9-osobowych</strong>, przez luksusowe <strong>Mercedesy dla 26 osób</strong>, aż po komfortowe <strong>autokary Scania dla 50 pasażerów</strong>.</p>
                    </div>
                    <div class="atut-item">
                        <i class="icon-lock" style="color: #fecb2f; font-size: 1.5rem;"></i>
                        <strong>Bezpieczeństwo potwierdzone certyfikatami</strong>
                        <p>Wszystkie nasze pojazdy przechodzą rygorystyczne przeglądy techniczne, a kierowcy to wykwalifikowani specjaliści dbający o spokój podróżnych.</p>
                    </div>
                    <div class="atut-item">
                        <i class="icon-star" style="color: #fecb2f; font-size: 1.5rem;"></i>
                        <strong>Indywidualne podejście</strong>
                        <p>Każda grupa ma inne potrzeby. Przygotowujemy dedykowane wyceny i dostosowujemy przystanki do planu Twojej wycieczki.</p>
                    </div>
                </div>

                <p style="margin-top: 25px; font-style: italic; color: #555;">
                    Zapraszamy do współpracy szkoły, biura podróży, instytucje publiczne oraz klientów indywidualnych. Z Pas-Trans każda podróż staje się przyjemnością.
                </p>
            </div>
        </div>
    </section>

    <section id="miasta-linki" class="container">
        <h2 class="section-title">Wynajem autokarów – gdzie działamy?</h2>
        <p style="text-align: center; margin-bottom: 30px; color: #666;">
            Zapewniamy transport osób z największych miast regionu. Sprawdź szczegóły oferty dla Twojej miejscowości:
        </p>
        
        <div class="miasta-pills">
            <a href="/wynajem-autokaru/Biedrzychowice/" class="miasto-pill">
                <i class="icon-location"></i> Biedrzychowice
            </a>
            <a href="/wynajem-autokaru/Bogatynia/" class="miasto-pill">
                <i class="icon-location"></i> Bogatynia
            </a>
            <a href="/wynajem-autokaru/Boleslawiec/" class="miasto-pill">
                <i class="icon-location"></i> Bolesławiec
            </a>
            <a href="/wynajem-autokaru/Gryfow-Slaski/" class="miasto-pill">
                <i class="icon-location"></i> Gryfów Śląski
            </a>
            <a href="/wynajem-autokaru/Jelenia-Gora/" class="miasto-pill">
                <i class="icon-location"></i> Jelenia Góra
            </a>
            <a href="/wynajem-autokaru/Luban/" class="miasto-pill">
                <i class="icon-location"></i> Lubań
            </a>
            <a href="/wynajem-autokaru/Olszyna/" class="miasto-pill">
                <i class="icon-location"></i> Olszyna
            </a>
            <a href="/wynajem-autokaru/Sulików/" class="miasto-pill">
                <i class="icon-location"></i> Sulików
            </a>
            <a href="/wynajem-autokaru/Zgorzelec/" class="miasto-pill">
                <i class="icon-location"></i> Zgorzelec
            </a>
        </div>
    </section>
</BaseLayout>